# ── Ignore everything by default ──────────────────────────
*

# ── Always include these ───────────────────────────────────
!.gitignore
!deploy.sh

# ── Include ALL html files (new dashboards auto-included) ──
!*.html

# ── Never commit data files ────────────────────────────────
*.xlsx
*.xlsm
*.xls
*.csv
~$*
*.pptx
*.docx
*.pdf
*.zip
*.json
