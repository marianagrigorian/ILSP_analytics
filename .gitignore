# ── Ignore everything by default ──────────────────────────
*

# ── Always include these ───────────────────────────────────
!.gitignore
!deploy.sh

# ── Include ALL html files (new dashboards auto-included) ──
!*.html

# ── Include server & config files ──────────────────────────
!api/
!api/chat.js
!package.json
!vercel.json

# ── Never commit data files ────────────────────────────────
*.xlsx
*.xlsm
*.xls
*.csv
~$*
*.pptx
*.docx
*.pdf
*.zip
*.json

# ── Re-include specific json files after *.json exclusion ──
!package.json
!vercel.json
